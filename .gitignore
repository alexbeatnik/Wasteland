# ============================================================================
# Wasteland .gitignore
# ============================================================================

# Build artifacts
/build/
/cmake-build-*/
/out/

# Python venv (used for cmake installation)
/.venv/

# Models (large binary files, never commit)
/models/*.gguf
/models/*.bin

# Object files, libraries, executables
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe
Wasteland

# Generated files
Makefile
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
_deps/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
*.user
*.sublime-*

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Debug / Profiling
*.dSYM/
*.pdb
*.ilk
*.stackdump
core
core.*
vgcore.*

# Temporary files
*.tmp
*.temp
*.log
*.bak

# Test scratch directories (created by ctest suites; should live under build/
# but appear at repo root when tests are run from there by mistake)
/wst_test_ws/
/wst_test_exec_ws/
/Testing/
